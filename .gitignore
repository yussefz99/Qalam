# Miscellaneous
*.class
*.log
*.pyc
__pycache__/

# Audio pipeline: raw recordings dropped in staging/ are never committed
# (they are normalized into assets/audio/). Keep the folder via .gitkeep.
tools/audio_pipeline/staging/*
!tools/audio_pipeline/staging/.gitkeep
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Vendored reference clone of community subagents (not part of Qalam; has its own .git)
/awesome-claude-code-subagents/

# Generated localizations (gen-l10n output) — regenerated from lib/l10n/*.arb on build
/lib/l10n/app_localizations*.dart

# Golden test diff artifacts (generated on failure, not source)
test/failures/
**/failures/

# Graphify knowledge-graph output (generated, large; rebuilt from source)
/graphify-out/
/.planning/graphs/

# GSD auto-checkpoint (regenerated each session)
/.planning/HANDOFF.json

# Flutter DevTools per-machine config (auto-generated)
devtools_options.yaml

# Node deps for the presentation deck builder (install with npm, not vendored)
docs/presentation/node_modules/
docs/presentation/~$*

# Firebase admin-SDK service-account keys (NEVER commit — elevation-of-privilege,
# threat T-06.1-02). google-services.json + firebase_options.dart are NOT secrets
# (Firebase guidance, research Q2) and stay committed; only the private SA key is
# excluded. Python seed/export tooling references it via GOOGLE_APPLICATION_CREDENTIALS.
tools/firebase/*serviceAccount*.json
tools/firebase/*.key.json
tools/firebase/*adminsdk*.json
tools/curriculum/*serviceAccount*.json
tools/curriculum/*.key.json
tools/curriculum/*adminsdk*.json

# TTS API keys (ElevenLabs) — never commit
tools/tts/.env
tools/tts/*.env

# Curriculum source worksheets (large binaries) + rendered pages — local only, not committed
tools/curriculum/source/
tools/curriculum/render/
