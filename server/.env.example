# Qalam tutor server — environment template.
#
# Copy to `.env` for LOCAL dev only. NEVER commit a real `.env`; it is gitignored and
# excluded from the Docker image (.dockerignore). On Cloud Run these values are injected
# from Secret Manager via `--set-secrets`, never baked into the image or shipped to the client.

# --- GCP / Firebase ---
# The Firebase/GCP project the App Check + Firebase ID tokens are minted for and verified against.
GCP_PROJECT_ID=qalam-app-bd7d0

# --- Provider API keys (Secret Manager on Cloud Run; placeholders only here) ---
# Real values live in Secret Manager (secrets ANTHROPIC_API_KEY / GOOGLE_API_KEY) and are
# injected as env vars by the Cloud Run runtime service account. The auth layer (app/auth.py)
# reads NO provider key — keys are consumed only by the models (Plan 02). Listed here so the
# deploy contract is explicit.
ANTHROPIC_API_KEY=__REPLACE_ME_LOCAL_DEV_ONLY__
GOOGLE_API_KEY=__REPLACE_ME_LOCAL_DEV_ONLY__

# --- Model routing (env-driven, eval-tunable; 14-AI-SPEC §4) ---
# Defaults live in code; override here to retune without a redeploy of code.
COACH_MODEL=claude-haiku-4-5
COACH_MODEL_PROVIDER=anthropic

# --- Request budget ---
# Per-request graph timeout (seconds). A slow model returns fast so the client degrades
# to its AuthoredFallback floor instead of hanging the trace loop (G5 / AI-SPEC §3).
COACH_TIMEOUT_SECONDS=8
