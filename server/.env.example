# Qalam tutor server — environment template.
#
# Copy to `.env` for LOCAL dev only. NEVER commit a real `.env`; it is gitignored and
# excluded from the Docker image (.dockerignore). On Cloud Run these values are injected
# via `--set-env-vars`, never baked into the image or shipped to the client.
#
# KEYLESS (D-02): the server authenticates to Vertex AI via the runtime service account's
# Application Default Credentials — there is NO provider API key (no ANTHROPIC_API_KEY, no
# GOOGLE_API_KEY) in the image, in Secret Manager, or on the client. All three nodes run
# Gemini-on-Vertex keyless; this is already the live `qalam-tutor` deploy. The auth layer
# (app/auth.py) reads NO provider key — it only verifies the CALLER (Firebase ID token + App Check).

# --- GCP / Firebase ---
# The Firebase/GCP project the App Check + Firebase ID tokens are minted for and verified against.
# Also the Vertex AI project the models run in (keyless ADC).
GCP_PROJECT_ID=qalam-app-bd7d0

# --- Model routing (env-driven, eval-tunable; 14-AI-SPEC §4 / 16-RESEARCH D-02) ---
# Defaults live in code (app/models.py) — the live KEYLESS Gemini-on-Vertex baseline. Override
# here to retune the routing WITHOUT a code change.
COACH_MODEL=gemini-2.5-flash
COACH_MODEL_PROVIDER=google_vertexai

# --- GATED UPGRADE: Claude-on-Vertex coach (D-03) — DO NOT uncomment yet ---
# Enable ONLY AFTER (a) a human clicks Enable on the Claude card in Vertex AI Model Garden for
# project qalam-app-bd7d0 (it is 404 "no access" until then), AND (b) the eval (`make eval`)
# picks Claude over Gemini on the Arabic-register dimension. Still keyless (runtime SA ADC) —
# NO ANTHROPIC_API_KEY. Claude does NOT serve us-central1; use COACH_LOCATION=global.
# COACH_MODEL=claude-haiku-4-5@20251001
# COACH_MODEL_PROVIDER=anthropic_vertex
# COACH_LOCATION=global

# --- Request budget ---
# Per-request graph timeout (seconds). A slow model returns fast so the client degrades
# to its AuthoredFallback floor instead of hanging the trace loop (G5 / AI-SPEC §3). The live
# deploy uses 12.
COACH_TIMEOUT_SECONDS=12
