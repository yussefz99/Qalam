rules_version = '2';

// Qalam Firestore security rules.
//
// Phase 06.1 — curriculum backend. Decisions enforced here:
//   D-10  Curriculum is readable by ANY signed-in identity (anonymous OK);
//         ALL client writes are denied. Content is written only by the
//         admin-SDK tooling (Plan 03), which bypasses these rules.
//   D-10a App Check is deferred to Phase 10. These rules contain no construct
//         that would conflict with enabling App Check later (no request.app
//         dependence either way) — App Check can be layered on without a rewrite.
//   D-11  NO child profile / progress / stroke data lives in Firestore this
//         phase. There is deliberately NO child-data collection match below;
//         the deny-by-default catch-all blocks any such path. Child data stays
//         in local Drift only — zero child PII surface in Firestore.
//
// Phase 07 — learning engine (Schema v2). The new curriculum collections
//   words/{wordId}, exercises/{exerciseId}, units/{letterId}
// INHERIT the same posture as letters/lessons/meta: read-requires-auth +
// all client writes denied (D-10). They are curriculum content, written only
// via the admin-SDK tooling; no child data lives in them (D-11 preserved — the
// deny-by-default catch-all still blocks any child-data path).
//
// v2 custom-claim seam: when roles (parent/admin/tutor) arrive, tighten the
// write rules by uncommenting and adapting the role guard shown inline below.
// Until then every collection is read-requires-auth + write-denied.

service cloud.firestore {
  match /databases/{database}/documents {

    // Curriculum: letters — readable by any signed-in identity (incl. anonymous);
    // no client writes (seeded/edited only via the admin-SDK tooling).
    match /letters/{letterId} {
      allow read: if request.auth != null;
      // v2 custom-claim seam (currently denied for all clients):
      //   allow write: if request.auth.token.role == 'admin';
      allow write: if false;
    }

    // Curriculum: lessons — same policy as letters.
    match /lessons/{lessonId} {
      allow read: if request.auth != null;
      // v2 custom-claim seam:
      //   allow write: if request.auth.token.role == 'admin';
      allow write: if false;
    }

    // Curriculum config/meta (e.g. meta/toleranceRamp) — same policy.
    match /meta/{doc} {
      allow read: if request.auth != null;
      // v2 custom-claim seam:
      //   allow write: if request.auth.token.role == 'admin';
      allow write: if false;
    }

    // Schema v2: words — readable by any signed-in identity; no client writes
    // (curriculum content, seeded/edited only via the admin-SDK tooling).
    match /words/{wordId} {
      allow read: if request.auth != null;
      // v2 custom-claim seam:
      //   allow write: if request.auth.token.role == 'admin';
      allow write: if false;
    }

    // Schema v2: exercises — same policy as words.
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
      // v2 custom-claim seam:
      //   allow write: if request.auth.token.role == 'admin';
      allow write: if false;
    }

    // Schema v2: units (per-letter unit config, units/{letterId}) — same policy.
    match /units/{letterId} {
      allow read: if request.auth != null;
      // v2 custom-claim seam:
      //   allow write: if request.auth.token.role == 'admin';
      allow write: if false;
    }

    // Phase 18 — the DERIVED across-session child model (D-13 / D-16, 18-05).
    // child_models/{uid} is the nightly-compiled, derived-only, fixed-vocabulary,
    // non-PII profile doc (strengths/struggles/perCriterion EMA). The device does a
    // background one-shot .get() to refresh its local Drift mirror (D-16), so it needs
    // an OWNER-scoped READ. Writes stay DENY-ALL — the doc is written ONLY by the
    // Cloud Run Admin SDK (which bypasses these rules), never by a client (D-13). The
    // owner-only read (request.auth.uid == uid) is the elevation-of-privilege guard:
    // account A can never read account B's model. The evidence subcollection
    // (children/{uid}/evidence/**) has DELIBERATELY no client match — the deny-all
    // catch-all below blocks it (Admin-only, append-only, server-written).
    match /child_models/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Deny-by-default catch-all. Any path not explicitly matched above —
    // including any future/accidental child-data path (D-11) and the Admin-only
    // children/{uid}/evidence/** subcollection — is denied for both read and write
    // to every client. MUST stay LAST.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
